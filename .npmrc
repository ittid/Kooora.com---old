# Hoist React + Next ecosystem to the top-level node_modules so Next.js's
# webpack runtime references stable paths instead of pnpm's hashed ones.
# Without this, `pnpm add` invalidates .next/ and causes:
#   Cannot find module './vendor-chunks/<pkg>@<v>_react@19.0.0.js'
public-hoist-pattern[]=*react*
public-hoist-pattern[]=*next*
public-hoist-pattern[]=*supabase*
public-hoist-pattern[]=*@types*

# Use a flat node_modules layout for first-level deps. Slower install,
# stable paths.
shamefully-hoist=true
